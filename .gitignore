## 🚫 9. .gitignore

### `.gitignore`
```gitignore
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
pythonenv*

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints
*/.ipynb_checkpoints/*

# Data
data/raw/*.csv
data/processed/*.csv
*.csv
*.xlsx
*.xls

# Models
models/*.pkl
models/*.h5
models/*.joblib

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log

# Environment variables
.env
.env.local
.env.*.local

# Docker
*.pid
docker-compose.override.yml

# Streamlit
.streamlit/secrets.toml

# API keys
*.key
*.pem
*.p12
*.pfx

# Virtual environment
venv/
env/
ENV/
myenv/

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Sphinx documentation
docs/_build/
doc/_build/

# PyBuilder
target/

# Jupyter
.ipynb_checkpoints

# pyenv
.python-version

# celery beat schedule
celerybeat-schedule

# SageMath parsed files
*.sage.py

# dotenv
.env

# virtualenv
venv/
ENV/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# Testing
test_*.py
*_test.py

# Backup files
*~
*.bak